# kagetra_new 本番 env テンプレート。実値は /opt/kagetra/.env.production (mode 0600, owner kagetra) に書く。
# scripts/deploy/apply-migrations.sh、docker compose、systemd unit、mail-worker が EnvironmentFile として読む。

# === Database (Docker postgres) ===
POSTGRES_DB=kagetra
POSTGRES_USER=kagetra
POSTGRES_PASSWORD=CHANGEME_strong_password_32_or_more_chars
DATABASE_URL=postgres://kagetra:CHANGEME_strong_password_32_or_more_chars@127.0.0.1:5432/kagetra?sslmode=disable

# === Auth.js (apps/web) ===
# AUTH_SECRET は `openssl rand -base64 32` で生成、dev の test secret は絶対流用しない
AUTH_SECRET=CHANGEME_openssl_rand_base64_32
NEXTAUTH_URL=https://new.hokudaicarta.com
# reverse proxy (nginx) 配下では Auth.js v5 が X-Forwarded-* を信頼するため必須。
# 設定し忘れると `/` → `/auth/signin` → `/` の無限 redirect ループに陥り
# ブラウザに ERR_TOO_MANY_REDIRECTS が出る (本番初回デプロイで踏んだ罠)。
# dev (localhost) では auto-trust されるため不要。
AUTH_TRUST_HOST=true

# === LINE Login (production channel、新規取得) ===
# redirect URI: https://new.hokudaicarta.com/api/auth/callback/line
AUTH_LINE_ID=CHANGEME
AUTH_LINE_SECRET=CHANGEME
LINE_LOGIN_CHANNEL_ID=CHANGEME
LINE_LOGIN_CHANNEL_SECRET=CHANGEME
LINE_LOGIN_CALLBACK_URL=https://new.hokudaicarta.com/api/line-link/callback

# === API ===
# NEXT_PUBLIC_API_URL は dev/prod 共通で /hono-api (Hono basePath、Phase B Option B)
NEXT_PUBLIC_API_URL=/hono-api
FRONTEND_URL=https://new.hokudaicarta.com
# PORT は systemd unit 内で web=3000、api=3001 を個別設定するので、ここでは設定しない

# === mail-worker (既存 docs/deploy/mail-worker.md と整合) ===
ANTHROPIC_API_KEY=CHANGEME
YAHOO_IMAP_USER=CHANGEME@yahoo.co.jp
YAHOO_IMAP_APP_PASSWORD=CHANGEME
YAHOO_IMAP_HOST=imap.mail.yahoo.co.jp
YAHOO_IMAP_PORT=993
MAIL_WORKER_PDF_SIZE_LIMIT_KB=800

# === mail-triage-badge: Web Push (VAPID) ===
# 新着メール通知 + 未処理バッジ。鍵ペア生成: npx web-push generate-vapid-keys
# 公開鍵は apps/web のクライアントに露出（NEXT_PUBLIC_）、秘密鍵は mail-worker の配信専用。
NEXT_PUBLIC_VAPID_PUBLIC_KEY=CHANGEME_vapid_public_key
VAPID_PRIVATE_KEY=CHANGEME_vapid_private_key
VAPID_SUBJECT=mailto:admin@hokudaicarta.com

# === Cloudflare R2 Backup (Phase C) ===
# R2 token は dashboard > R2 > Manage R2 API Tokens > "Object Read & Write" 権限で発行。
# bucket scope 限定が推奨 (Admin 権限は不要)。
# Object 権限 token は ListBuckets 不可なので、backup.sh は
# RCLONE_CONFIG_R2_NO_CHECK_BUCKET=true を export して回避する。
R2_ACCOUNT_ID=CHANGEME_cloudflare_account_id
R2_ACCESS_KEY_ID=CHANGEME_r2_access_key_id
R2_SECRET_ACCESS_KEY=CHANGEME_r2_secret_access_key
R2_BUCKET=kagetra-backup
# BACKUP_LOCAL_DIR は省略可 (default: /var/backups/kagetra)
# BACKUP_LOCAL_DIR=/var/backups/kagetra
# KAGETRA_REPO_ROOT は省略可 (default: /opt/kagetra)
# KAGETRA_REPO_ROOT=/opt/kagetra

# === LINE Fallback Notification (Phase C) ===
# notify-system.ts (DB-backed system_channel) が postgres 障害で動かない場合の
# 二段目フォールバック。設定しない場合、postgres down に伴う backup 失敗は
# journalctl のみで検知することになる (LINE 通知が来ない)。
# token/userId は production LINE channel + 管理者 LINE userId を流用可能で、
# system_channel の値と同じでも問題ない (DB を介さず env 直読みする CLI なので、
# postgres 障害下でも独立して機能する)。
# 値が両方とも空なら notify-fallback.ts は silent skip し、journal に
# `[notify-fallback] skipped: env-not-configured` を残す。
LINE_FALLBACK_CHANNEL_ACCESS_TOKEN=CHANGEME_optional_for_db_independent_alerts
LINE_FALLBACK_NOTIFY_USER_ID=CHANGEME_optional_admin_user_id
