DATABASE_URL=postgresql://kagetra:kagetra_dev@localhost:5433/kagetra
FRONTEND_URL=http://localhost:3000

# Auth.js — sign JWT + cookie names
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Auth.js LINE provider (primary login). Auth.js auto-reads AUTH_LINE_ID/AUTH_LINE_SECRET.
# Create a "LINE Login" channel at https://developers.line.biz/console/ and set
# its callback URL to <base>/api/auth/callback/line (Auth.js default).
AUTH_LINE_ID=
AUTH_LINE_SECRET=

# LINE account switch (/settings/line-link) — legacy raw OAuth2 flow.
# Separate channel (or same as AUTH_LINE_*); callback URL below is for the
# account-switch route, NOT the primary login.
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_CALLBACK_URL=http://localhost:3000/api/line-link/callback

# Testing switch (Vitest / Playwright only). When 'true' AND NODE_ENV !== 'production',
# the callback handler skips real HTTP calls to LINE and returns a deterministic
# profile. Keep this UNSET in production.
# LINE_OAUTH_TEST_MODE=true

# Mail worker (apps/mail-worker) — Yahoo!IMAP credentials.
# Generate an app password at https://accounts.yahoo.co.jp/account/manage/security/app-password
# Required only for live IMAP runs; --mock-imap skips this check.
YAHOO_IMAP_HOST=imap.mail.yahoo.co.jp
YAHOO_IMAP_PORT=993
YAHOO_IMAP_USER=
YAHOO_IMAP_APP_PASSWORD=

# Mail worker log level: debug | info | warn | error (default: info).
# MAIL_WORKER_LOG_LEVEL=info

# Anthropic API key for the AI classifier (PR3+). Generate at
# https://console.anthropic.com/settings/keys. Required only for live AI runs;
# `--mock-llm` and `--dry-run` flags skip this check.
ANTHROPIC_API_KEY=
